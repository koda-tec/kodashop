// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  stores    Store[]  // Un usuario tiene muchas tiendas
  createdAt DateTime @default(now())
}

model Store {
  id            String   @id @default(uuid())
  name          String
  subdomain     String   @unique
  ownerEmail    String
  userId        String   // ID del dueño
  user          User     @relation(fields: [userId], references: [id])
  products      Product[] // <--- RELACIÓN: Una tienda tiene muchos productos
  createdAt     DateTime @default(now())
}

// 📦 NUEVO MODELO DE PRODUCTOS
model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  images      String[] // Array de URLs (lo que usaremos para las fotos)
  stock       Int      @default(0)
  
  storeId     String   // ID de la tienda a la que pertenece
  store       Store    @relation(fields: [storeId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}