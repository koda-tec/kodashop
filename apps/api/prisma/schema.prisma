// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  stores    Store[]  // Un usuario tiene muchas tiendas
  createdAt DateTime @default(now())
}
model Store {
  id            String    @id @default(uuid())
  name          String
  subdomain     String    @unique
  ownerEmail    String
  pixelId       String?   // Facebook Pixel ID
  capiToken     String?   // Facebook Conversion API Access Token
  testEventCode String?   // Código de prueba de eventos (TEST12345)
  
  metaVerification  String?   // Para el meta-tag de verificación
  googleAnalyticsId String?   // ID de GA4 (G-XXXXXXXX)
  customHeadScripts String?   // Scripts personalizados en el <head>
  // --- Branding & Config ---
  logo          String?
  primaryColor  String    @default("#2563eb")
  secondaryColor String   @default("#0f172a")
  templateId    String    @default("default") // Para cambiar entre diseños

  announcement    String?   // "Envío gratis a todo el país"
  heroTitle       String?   // "La mejor tecnología en tus manos"
  heroSubtitle    String?   // "Calidad garantizada al mejor precio"
  whatsapp        String?   // Número de contacto
  banners         String[]  // Array de URLs de Cloudinary para el carrusel

  // -------------------------
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  products      Product[]
  categories    Category[]
  variantTypes  VariantType[]
  createdAt     DateTime  @default(now())
}

model Category {
  id        String    @id @default(uuid())
  name      String
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id])
  products  Product[]
}

model Product {
  id           String    @id @default(uuid())
  name         String
  description  String?
  price        Float
  costPrice    Float?    // Cuánto te costó el producto (para calcular ganancia)
  saleEndsAt   DateTime? // Cuándo termina la oferta
  status       String    @default("PUBLISHED") // DRAFT o PUBLISHED
  isHot        Boolean   @default(false)       // Etiqueta de "Hot"
  slug         String?   // URL amigable
  comparePrice Float?
  sku          String?  
  images       String[]
  videos       String[]  
  stock        Int       @default(0)
  // Relaciones
  storeId      String
  store        Store     @relation(fields: [storeId], references: [id])
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  variants     ProductVariant[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Para que el usuario cree "Talle", "Color", "Material"
model VariantType {
  id        String   @id @default(uuid())
  name      String   // Ej: "Color"
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  values    String[] // Ej: ["Rojo", "Azul"]
}

model ProductVariant {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  combination Json     // Ej: {"Color": "Rojo", "Talle": "XL"}
  price       Float?   // Precio específico si cambia
  stock       Int      @default(0)
}